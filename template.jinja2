#
# iOS {{ which.capitalize() }} Mode Theme - {{ color }}
#
ios-{{ which }}-mode-{{ color }}{{ suffix }}:
  # Global
  background-image: "center / cover no-repeat fixed url('/{{ folder }}/themes/ios-themes/{{ background_jpg }}')"
  lovelace-background: var(--background-image)
  primary-color: {{ primary_color }}  # from Apple systemOrange {{ which }} mode
  light-primary-color: {{ light_primary_color }}  # (icons on left menu) (light: systemGray5 from iOS dark mode, dark: XXX)
  primary-background-color: {{ primary_background_color }}  # systemGray5 {{ which }} mode
  secondary-background-color: {{ secondary_background_color }}
  divider-color: {{ divider_color }}  # from Apple systemGray {{ which }} mode
  accent-color: rgba(255, 159, 9, 1)
  # Text
  primary-text-color: {{ primary_text_color }}
  secondary-text-color: {{ secondary_text_color }}
  text-primary-color: "#FFF"
  disabled-text-color: {{ disabled_text_color }}
  text-dark-color: "#FFF"
  # Sidebar Menu
  sidebar-background-color: var(--primary-background-color)
  sidebar-icon-color: var(--light-primary-color)
  sidebar-text-color: {{ sidebar_text_color }}
  sidebar-selected-background-color: var(--primary-background-color)
  sidebar-selected-icon-color: {{ sidebar_selected_icon_color }}  # (light: systemGray5 from iOS light mode, dark: XXX)
  sidebar-selected-text-color: var(--sidebar-selected-icon-color)
  # States and Badges
  state-icon-color: "#FFF"
  state-icon-active-color: {{ state_icon_active_color }}  # or make light icons yellow when active: rgba(255, 214, 10, 1)
  state-icon-unavailable-color: var(--disabled-text-color)
  paper-item-icon-active-color: {{ state_icon_active_color }}  # see https://github.com/basnijholt/lovelace-ios-dark-mode-theme/issues/30
  # Sliders
  paper-slider-knob-color: "#FFFFFF"
  paper-slider-knob-start-color: var(--paper-slider-knob-color)
  paper-slider-pin-color: var(--paper-slider-knob-color)
  paper-slider-active-color: {{ paper_slider_active_color }}  # from Apple systemBlue {{ which }} mode
  paper-slider-secondary-color: var(--paper-slider-knob-color)
  paper-slider-container-color: rgba(255, 255, 255, 0.5)
  paper-slider-font-color: "#000"
  ha-slider-background: none !important
  # Labels
  label-badge-background-color: "#23232E"
  label-badge-text-color: "#F1F1F1"
  label-badge-red: {{ label_badge_red }}  # from Apple systemOrange {{ which }} mode
  # Cards
  card-background-color: var(--secondary-background-color)  # Unused entities table background
  paper-listbox-background-color: var(--primary-background-color)
  ha-card-border-radius: 20px
  ha-card-background: {{  ha_card_background }}
  paper-card-background-color: var(--ha-card-background)
  rgb-card-background-color: {{ rgb_card_background }} # see https://github.com/basnijholt/lovelace-ios-themes/issues/60
  ha-card-border-width: 0  # https://github.com/basnijholt/lovelace-ios-dark-mode-theme/issues/82#event-7732695357
  # Toggles
  paper-toggle-button-checked-button-color: "#484848"
  paper-toggle-button-checked-bar-color: "#484848"
  paper-toggle-button-unchecked-button-color: var(--paper-toggle-button-checked-button-color)
  paper-toggle-button-unchecked-bar-color: var(--disabled-text-color)
  # Table row
  table-row-background-color: var(--primary-background-color)
  table-row-alternative-background-color: var(--secondary-background-color)
  # Switches
  switch-checked-color: "#30d257"  # XXX: remove when https://github.com/home-assistant/home-assistant-polymer/pull/4203 is in HA
  switch-checked-track-color: {{ switch_checked_track_color }}  # from Apple systemGreen {{ which }} mode
  switch-checked-button-color: "#FFF"
  # Other
  paper-dialog-background-color: {{ paper_dialog_background_color }}  # e.g., background of more-info
  paper-item-icon-color: {{ paper_item_icon_color }}  # also should mini-media-player icon white (but doesn't work by itself)
  more-info-header-background: {{ more_info_header_background }}
  lumo-body-text-color: var(--primary-text-color)  # see https://github.com/basnijholt/lovelace-ios-dark-mode-theme/issues/42
  app-header-background-color: {{ app_header_background_color }}
  markdown-code-background-color: {{ markdown_code_background_color }}
  code-editor-background-color: {{ code_editor_background_color }}
  clear-background-color: var(--ha-card-background)  # see https://github.com/basnijholt/lovelace-ios-themes/issues/64
  # Custom
  mcg-title-letter-spacing: .15em
  mini-media-player-base-color: white
  mini-media-player-icon-color: white
  # Added for https://github.com/basnijholt/lovelace-ios-dark-mode-theme/issues/72
  # TODO: add description for lines below. Suggested in https://github.com/basnijholt/lovelace-ios-dark-mode-theme/issues/72
  {% if which == "dark" %}
  input-ink-color: var(--primary-text-color)
  input-fill-color: "#242426"
  input-disabled-fill-color: "#1f1f21"
  input-label-ink-color: rgba(255, 255, 255, 0.72)
  input-disabled-ink-color: var(--disabled-text-color)
  input-dropdown-icon-color: rgba(255, 255, 255, 0.72)
  input-idle-line-color: rgba(255, 255, 255, 0.45)
  input-hover-line-color: var(--accent-color)
  input-outlined-idle-border-color: rgba(255, 255, 255, 0.38)
  input-outlined-hover-border-color: var(--accent-color)
  mdc-theme-surface: "#1c1c1e"
  mdc-theme-on-surface: "#FFF"
  {% else %}
  input-ink-color: "#161a17"
  input-fill-color: rgba(255, 255, 255, 0.92)
  input-disabled-fill-color: rgba(255, 255, 255, 0.38)
  input-label-ink-color: rgba(22, 26, 23, 0.72)
  input-disabled-ink-color: rgba(22, 26, 23, 0.48)
  input-dropdown-icon-color: rgba(22, 26, 23, 0.72)
  input-idle-line-color: rgba(22, 26, 23, 0.38)
  input-hover-line-color: var(--accent-color)
  input-outlined-idle-border-color: rgba(22, 26, 23, 0.38)
  input-outlined-hover-border-color: var(--accent-color)
  mdc-theme-surface: "#f5f5f5"
  mdc-theme-on-surface: "#161a17"
  {% endif %}
  mdc-theme-background: var(--primary-background-color)
  mdc-theme-text-primary-on-background: var(--input-ink-color)
  mdc-theme-text-secondary-on-background: var(--input-label-ink-color)
  mdc-theme-text-disabled-on-background: var(--input-disabled-ink-color)
  material-background-color: var(--mdc-theme-surface)
  material-secondary-background-color: var(--primary-background-color)
  paper-input-container-color: var(--input-label-ink-color)
  paper-input-container-input-color: var(--input-ink-color)
  paper-input-container-focus-color: var(--accent-color)
  ha-textfield-fill-color: var(--input-fill-color)
  ha-textfield-ink-color: var(--input-ink-color)
  ha-textfield-label-ink-color: var(--input-label-ink-color)
  ha-select-fill-color: var(--input-fill-color)
  ha-select-ink-color: var(--input-ink-color)
  ha-select-label-ink-color: var(--input-label-ink-color)
  mdc-text-field-fill-color: var(--input-fill-color)
  mdc-text-field-disabled-fill-color: var(--input-disabled-fill-color)
  mdc-text-field-ink-color: var(--input-ink-color)
  mdc-text-field-label-ink-color: var(--input-label-ink-color)
  mdc-text-field-disabled-ink-color: var(--input-disabled-ink-color)
  mdc-text-field-idle-line-color: var(--input-idle-line-color)
  mdc-text-field-hover-line-color: var(--accent-color)
  mdc-select-fill-color: var(--input-fill-color)
  mdc-select-disabled-fill-color: var(--input-disabled-fill-color)
  mdc-select-ink-color: var(--input-ink-color)
  mdc-select-label-ink-color: var(--input-label-ink-color)
  mdc-select-disabled-ink-color: var(--input-disabled-ink-color)
  mdc-select-dropdown-icon-color: var(--input-dropdown-icon-color)
  mdc-select-idle-line-color: var(--input-idle-line-color)
  mdc-select-hover-line-color: var(--accent-color)
  mdc-filled-text-field-container-color: var(--input-fill-color)
  mdc-filled-text-field-disabled-container-color: var(--input-disabled-fill-color)
  mdc-filled-text-field-input-text-color: var(--input-ink-color)
  mdc-filled-text-field-label-text-color: var(--input-label-ink-color)
  mdc-filled-text-field-hover-label-text-color: var(--input-ink-color)
  mdc-filled-text-field-focus-label-text-color: var(--accent-color)
  mdc-filled-text-field-disabled-input-text-color: var(--input-disabled-ink-color)
  mdc-filled-text-field-disabled-label-text-color: var(--input-disabled-ink-color)
  mdc-filled-text-field-active-indicator-color: var(--input-idle-line-color)
  mdc-filled-text-field-hover-active-indicator-color: var(--accent-color)
  mdc-filled-text-field-focus-active-indicator-color: var(--accent-color)
  mdc-filled-select-container-color: var(--input-fill-color)
  mdc-filled-select-disabled-container-color: var(--input-disabled-fill-color)
  mdc-filled-select-selected-text-color: var(--input-ink-color)
  mdc-filled-select-label-text-color: var(--input-label-ink-color)
  mdc-filled-select-hover-label-text-color: var(--input-ink-color)
  mdc-filled-select-focus-label-text-color: var(--accent-color)
  mdc-filled-select-disabled-selected-text-color: var(--input-disabled-ink-color)
  mdc-filled-select-disabled-label-text-color: var(--input-disabled-ink-color)
  mdc-filled-select-dropdown-icon-color: var(--input-dropdown-icon-color)
  mdc-filled-select-disabled-dropdown-icon-color: var(--input-disabled-ink-color)
  mdc-filled-select-active-indicator-color: var(--input-idle-line-color)
  mdc-filled-select-hover-active-indicator-color: var(--accent-color)
  mdc-filled-select-focus-active-indicator-color: var(--accent-color)
  md-sys-color-primary: var(--accent-color)
  md-sys-color-on-surface: var(--input-ink-color)
  md-sys-color-on-surface-variant: var(--input-label-ink-color)
  md-sys-color-surface: var(--mdc-theme-surface)
  md-sys-color-surface-container-highest: var(--input-fill-color)
  md-sys-color-outline: var(--input-outlined-idle-border-color)
  md-filled-text-field-container-color: var(--input-fill-color)
  md-filled-text-field-input-text-color: var(--input-ink-color)
  md-filled-text-field-label-text-color: var(--input-label-ink-color)
  md-filled-text-field-hover-label-text-color: var(--input-ink-color)
  md-filled-text-field-focus-label-text-color: var(--accent-color)
  md-filled-text-field-active-indicator-color: var(--input-idle-line-color)
  md-filled-text-field-hover-active-indicator-color: var(--accent-color)
  md-filled-text-field-focus-active-indicator-color: var(--accent-color)
  md-filled-select-text-field-container-color: var(--input-fill-color)
  md-filled-select-text-field-input-text-color: var(--input-ink-color)
  md-filled-select-text-field-label-text-color: var(--input-label-ink-color)
  md-filled-select-text-field-hover-label-text-color: var(--input-ink-color)
  md-filled-select-text-field-focus-label-text-color: var(--accent-color)
  md-filled-select-text-field-active-indicator-color: var(--input-idle-line-color)
  md-filled-select-text-field-hover-active-indicator-color: var(--accent-color)
  md-filled-select-text-field-focus-active-indicator-color: var(--accent-color)
  codemirror-property: var(--accent-color)
